# 로컬 FastAPI 전용 (.env.example 복사 후 값 입력)
API_PORT=8100
DATABASE_URL=postgresql+asyncpg://healthkeeper:CHANGE_ME@127.0.0.1:15432/healthkeeper
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:16379/0
NEO4J_URI=bolt://127.0.0.1:17687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME
SECRET_KEY=local-dev-secret-change-in-production
DEBUG=true
APP_BASE_URL=http://localhost:5173
SSO_PROVIDER=mock
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:5173/api/auth/sso/callback
SSO_ALLOWED_DOMAIN=ibank.co.kr,digitalworks.co.kr
SSO_SUCCESS_PATH=/reserve
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=healthkeeper@ibank.co.kr
SMTP_PASSWORD=
SMTP_FROM=healthkeeper@ibank.co.kr
SMTP_FROM_NAME=헬스키퍼
SMTP_USE_TLS=true
