# 로컬 FastAPI — 루트 .env 와 dev.sh 가 동기화합니다
API_PORT=8100
DATABASE_URL=postgresql+asyncpg://healthkeeper:localdev@127.0.0.1:54321/healthkeeper
REDIS_URL=redis://:localdev@127.0.0.1:63791/0
SECRET_KEY=local-dev-secret-change-in-production
DEBUG=true
APP_BASE_URL=http://localhost:5173
SSO_PROVIDER=mock
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:5173/api/auth/sso/callback
SSO_ALLOWED_DOMAIN=ibank.co.kr,digitalworks.co.kr
SSO_SUCCESS_PATH=/reserve
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=healthkeeper@ibank.co.kr
SMTP_PASSWORD=
SMTP_FROM=healthkeeper@ibank.co.kr
SMTP_FROM_NAME=헬스키퍼
SMTP_USE_TLS=true

# 공공데이터포털 공휴일 API (디코딩된 ServiceKey)
PUBLIC_DATA_PORTAL_SERVICE_KEY=
