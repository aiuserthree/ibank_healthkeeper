# ===========================================
# 헬스키퍼 환경 변수 (예시)
# PostgreSQL · Redis는 원격 서버(115.68.221.73)에만 존재
# 로컬 개발 시 scripts/dev-tunnel.sh 로 SSH 터널 후 아래 localhost 사용
# ===========================================

# --- Database (원격 PostgreSQL + pgvector) ---
POSTGRES_USER=healthkeeper
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=healthkeeper
DATABASE_URL=postgresql+asyncpg://healthkeeper:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:15432/healthkeeper

# --- Redis (원격) ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:16379/0

# --- Neo4j (원격) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_NEO4J_PASSWORD
NEO4J_URI=bolt://127.0.0.1:17687

# --- SMTP (iwinv — maile002.roundcube.mail.iwinv.kr) ---
# @ibank.co.kr / @digitalworks.co.kr 수신 사서함이 M365(Outlook)인 경우
# iwinv에 해당 도메인 외부 MX 릴레이 요청 필요
SMTP_HOST=maile002.roundcube.mail.iwinv.kr
SMTP_PORT=587
SMTP_USER=noreply@ibank.co.kr
SMTP_PASSWORD=
SMTP_FROM=noreply@ibank.co.kr
SMTP_FROM_NAME=헬스키퍼
SMTP_USE_TLS=true

# --- App ---
API_PORT=8100
SECRET_KEY=CHANGE_ME_RANDOM_SECRET
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://healthkeeper.ibank.co.kr","http://115.68.221.73"]

# --- SSO (회원 Microsoft 로그인) ---
SSO_PROVIDER=mock
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:5173/api/auth/sso/callback
SSO_ALLOWED_DOMAIN=ibank.co.kr,digitalworks.co.kr
SSO_SUCCESS_PATH=/reserve
APP_BASE_URL=http://localhost:5173

# --- Remote server (배포/SSH용) ---
APP_DOMAIN=healthkeeper.ibank.co.kr
CERTBOT_EMAIL=admin@ibank.co.kr
REMOTE_HOST=115.68.221.73
REMOTE_USER=root
# ENABLE_NEO4J=true  # 선택 — Docker Hub 접근 가능할 때만
