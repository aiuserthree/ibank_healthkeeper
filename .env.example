# ===========================================
# 헬스키퍼 환경 변수 (예시)
# ===========================================

# --- 개발 DB 모드 (DEV_DB_MODE) ---
# local       = Mac Docker (54321/63791)
# remote-dev  = 서버 healthkeeper_dev + SSH 터널 (Docker 불필요, 운영과 분리) ★ 권장
# remote-prod = USE_REMOTE_DB=1 (운영 DB 직접 — 비권장)
DEV_DB_MODE=remote-dev
USE_REMOTE_DB=0
DEV_POSTGRES_DB=healthkeeper_dev
DEV_REDIS_DB=1

# --- Database (remote-dev: SSH 터널 후 아래 URL) ---
DATABASE_URL=postgresql+asyncpg://healthkeeper:CHANGE_ME@127.0.0.1:15432/healthkeeper_dev
REDIS_URL=redis://:CHANGE_ME@127.0.0.1:16379/1

# --- Database (local Docker — DEV_DB_MODE=local 일 때) ---
LOCAL_POSTGRES_PASSWORD=localdev
LOCAL_REDIS_PASSWORD=localdev
# DATABASE_URL=postgresql+asyncpg://healthkeeper:localdev@127.0.0.1:54321/healthkeeper
# REDIS_URL=redis://:localdev@127.0.0.1:63791/0

# --- Database (운영 deploy.sh — 서버 docker-compose) ---
POSTGRES_USER=healthkeeper
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=healthkeeper
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- Neo4j (선택) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_URI=

# --- SMTP ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=healthkeeper@ibank.co.kr
SMTP_PASSWORD=
SMTP_FROM=healthkeeper@ibank.co.kr
SMTP_FROM_NAME=헬스키퍼
SMTP_USE_TLS=true

# --- App ---
API_PORT=8100
SECRET_KEY=local-dev-secret-change-me
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://healthkeeper.ibank.co.kr","http://115.68.221.73"]

# --- SSO ---
SSO_PROVIDER=mock
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:5173/api/auth/sso/callback
SSO_ALLOWED_DOMAIN=ibank.co.kr,digitalworks.co.kr
SSO_SUCCESS_PATH=/reserve
APP_BASE_URL=http://localhost:5173

# --- Remote server (deploy.sh) ---
APP_DOMAIN=healthkeeper.ibank.co.kr
CERTBOT_EMAIL=admin@ibank.co.kr
REMOTE_HOST=115.68.221.73
REMOTE_USER=root
